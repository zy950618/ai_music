{
  "providers": [
    {
      "id": "musicgen_local_small",
      "provider": "local_command",
      "model_name": "facebook/musicgen-small",
      "model_version": "audiocraft-local",
      "enabled": true,
      "priority": 1,
      "supported_modes": ["instrumental", "bgm", "loop", "short_video", "classical", "game", "film"],
      "supports_vocals": false,
      "supports_instrumental": true,
      "max_duration_sec": 30,
      "command": [
        "python",
        "tools/musicgen_local_adapter.py",
        "--output",
        "{output_path}",
        "--duration-sec",
        "{duration_sec}",
        "--prompt",
        "{prompt}",
        "--model",
        "facebook/musicgen-small"
      ],
      "timeout_sec": 900,
      "notes": "Local AudioCraft MusicGen adapter for internal validation. facebook/musicgen-small weights are CC-BY-NC 4.0, so do not use this default config for commercial delivery."
    },
    {
      "id": "mock_fallback",
      "provider": "mock",
      "model_name": "mock_sine_arranger",
      "model_version": "0.1.0",
      "enabled": true,
      "priority": 100,
      "supported_modes": ["song", "instrumental", "bgm", "loop", "short_video", "children", "classical", "game", "film"],
      "supports_vocals": true,
      "supports_instrumental": true,
      "max_duration_sec": 600,
      "notes": "Fallback for local validation when AudioCraft is not installed."
    }
  ]
}
